{
  "name": "saeed-furniture-root",
  "version": "1.0.0",
  "description": "Root package for Saeed Furniture project deployment",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./frontend/input.css -o ./frontend/dist/output.css --minify",
    "build": "node -e \"require('fs').rmSync('node_modules', {recursive:true, force:true})\" && npm install && echo 'Build complete'",
    "start": "node ./saeed-backend/server.js"
  },
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/cli": "^4.3.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "morgan": "^1.11.0",
    "rate-limit-redis": "^4.3.1",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.3.0",
    "xss": "^1.0.15"
  }
}
