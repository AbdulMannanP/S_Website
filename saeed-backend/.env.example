# ─────────────────────────────────────────────────────────────
#  Saeed Furniture Backend — Environment Variables Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in real values in .env
#  3. NEVER commit your actual .env file to version control
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
# In production, replace with your real domain e.g. https://saeedfurniture.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Admin Dashboard
# Use a strong, unique password — NOT the example below
ADMIN_PASSWORD=CHANGE_ME_BEFORE_GOING_LIVE

# Session signing secret — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_GENERATE_A_REAL_48_BYTE_HEX_SECRET

# Supabase — get these from your Supabase project dashboard (Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Service Role Key for backend operations with elevated privileges
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
